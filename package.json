{
  "name": "dash-web",
  "version": "0.9.0",
  "private": true,
  "scripts": {
    "start": "ng serve -o",
    "start:dev": "npm run start -- -c=dev",
    "build": "ng build --configuration=production",
    "build:bundle-stats": "npm run build -- --stats-json",
    "test": "ng test",
    "test:watch": "npm run test -- --watch",
    "cy:open": "cypress open",
    "cy:verify": "npx cypress verify",
    "eslint": "eslint .",
    "eslint:fix": "npm run eslint -- --fix",
    "lint:styles": "stylelint \"src/**/*.{css,scss,sass}\" ",
    "lint:styles:fix": "npm run lint:styles -- --fix ",
    "lint:styles:report": "npm run lint:styles -- --formatter json --output-file ./styleLintReport.json",
    "code:check": "prettier . --check",
    "code:format": "prettier . --write",
    "compodoc:build": "compodoc -p tsconfig.doc.json",
    "compodoc:build-and-serve": "compodoc -p tsconfig.doc.json -s",
    "compodoc:serve": "compodoc -s",
    "bundle:analyze": "esbuild-visualizer --metadata ./public/stats.json --filename ./bundle-stats/index.html"
  },
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "dependencies": {
    "@angular/animations": "21.2.10",
    "@angular/cdk": "21.2.8",
    "@angular/common": "21.2.10",
    "@angular/compiler": "21.2.10",
    "@angular/core": "21.2.10",
    "@angular/forms": "21.2.10",
    "@angular/material": "21.2.8",
    "@angular/material-date-fns-adapter": "21.2.8",
    "@angular/platform-browser": "21.2.10",
    "@angular/platform-browser-dynamic": "21.2.10",
    "@angular/router": "21.2.10",
    "@angular/service-worker": "21.2.10",
    "@compodoc/compodoc": "1.2.1",
    "chart.js": "4.5.1",
    "date-fns": "4.1.0",
    "jwt-decode": "4.0.0",
    "leaflet": "1.9.4",
    "leaflet-sidebar-v2": "3.2.3",
    "ng2-charts": "8.0.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "21.2.8",
    "@angular/compiler-cli": "21.2.10",
    "@eslint/js": "10.0.1",
    "@types/leaflet": "1.9.21",
    "@types/node": "24.12.2",
    "angular-calendar": "0.32.2",
    "cypress": "14.5.4",
    "cypress-file-upload": "5.0.8",
    "cypress-multi-reporters": "2.0.5",
    "esbuild-visualizer": "0.7.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-cypress": "6.3.1",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "mochawesome": "7.1.4",
    "mochawesome-merge": "5.1.1",
    "mochawesome-report-generator": "6.3.2",
    "prettier": "3.8.3",
    "stylelint": "17.8.0",
    "stylelint-config-standard-scss": "17.0.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0",
    "vitest": "4.0.16"
  }
}
